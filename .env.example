# =============================================================================
# DeepMiro — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Every variable here is read by docker-compose.yml at the repo root.
# Two variables are strictly required:
#
#   LLM_API_KEY   your LLM provider's API key (Fireworks by default)
#   SURREAL_PASS  password for the SurrealDB root user
#                 (generate with: openssl rand -hex 32)
#
# Everything else has a working default.
#
# Note on the SurrealDB variable name: SURREAL_PASS is the NATIVE
# env var that `surreal start` reads directly — no flags or shell
# expansion needed. The backend also accepts the legacy
# SURREAL_PASSWORD name for backward compatibility, but SURREAL_PASS
# is preferred because it flows cleanly through to the surrealdb
# container without any compose interpolation.
#
# Railway users: don't commit this file. Paste each variable into the
# Railway dashboard (Variables tab). Railway does not read .env files
# directly — it injects variables at container start.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER (required)
# -----------------------------------------------------------------------------
# Any OpenAI-compatible API works: OpenAI, Fireworks, Anthropic (via proxy),
# Ollama, vLLM, LM Studio, etc. The engine never assumes a specific vendor.
#
# Default: Fireworks — cheapest, fastest, matches DeepMiro's actual
# production deployment. One key covers primary + boost + embeddings
# so it's the smoothest zero-config path. Sign up at fireworks.ai
# and paste your key into LLM_API_KEY below.
#
# Alternatives:
#
#   OpenAI      — highest reasoning quality, most expensive
#                 LLM_BASE_URL=https://api.openai.com/v1
#                 LLM_MODEL_NAME=gpt-4o-mini
#
#   Ollama      — fully local, free, slower
#                 LLM_BASE_URL=http://host.docker.internal:11434/v1
#                 LLM_MODEL_NAME=llama3.1:8b
#                 LLM_API_KEY=ollama  (ollama accepts any non-empty value)
#                 Linux note: host.docker.internal doesn't resolve on
#                 Linux by default. Use either:
#                   (a) add `extra_hosts: ["host.docker.internal:host-gateway"]`
#                       to the backend service in docker-compose.yml, or
#                   (b) point LLM_BASE_URL at http://172.17.0.1:11434/v1
#                       (the default docker0 bridge gateway IP)

# LLM_API_KEY is deliberately empty — compose will fail loudly rather
# than start the backend with a placeholder that looks valid but the
# LLM provider rejects later.
LLM_API_KEY=
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL_NAME=accounts/fireworks/models/minimax-m2p5


# -----------------------------------------------------------------------------
# BOOST LLM (optional)
# -----------------------------------------------------------------------------
# Used for reasoning-heavy tasks like report outline planning and the
# ReportAgent ReACT loop. A larger model here noticeably improves
# report quality at the cost of generating ~5-10% of total tokens.
# Unset = fall back to the primary LLM defined above.
#
# Fireworks default (same key as LLM_API_KEY, no extra signup):

# LLM_BOOST_API_KEY=${LLM_API_KEY}
# LLM_BOOST_BASE_URL=https://api.fireworks.ai/inference/v1
# LLM_BOOST_MODEL_NAME=accounts/fireworks/models/gpt-oss-120b


# -----------------------------------------------------------------------------
# GRAPH EMBEDDINGS (optional)
# -----------------------------------------------------------------------------
# Used to embed entity nodes and post content for the knowledge graph's
# hybrid HNSW + BM25 search. Must match the dimensions of the model —
# nomic-embed-text-v1.5 is 768.
#
# Defaults to nomic-embed via Fireworks. If you're using a Fireworks
# LLM_API_KEY above, the SAME key also works here — no extra signup.
# Override these only if you want to use a different embedding
# provider than your LLM provider.

# EMBEDDING_API_KEY=${LLM_API_KEY}
# EMBEDDING_BASE_URL=https://api.fireworks.ai/inference
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=768


# -----------------------------------------------------------------------------
# SURREALDB (SURREAL_PASS required)
# -----------------------------------------------------------------------------
# Root password for the SurrealDB service. No default — docker-compose
# will refuse to start if SURREAL_PASS is empty, and that's
# deliberate: a silent default would ship a root-privileged DB to
# everyone who clicks Deploy.
#
# Generate a strong one once:
#   openssl rand -hex 32
#
# On Railway, set SURREAL_PASS on BOTH the `surrealdb` service and
# the `backend` service (same value). Use their "Generate" button
# for a random value if you prefer.

SURREAL_USER=root
SURREAL_PASS=

# namespace + database are static in our compose file (mirofish /
# production). Override them by editing docker-compose.yml directly
# if you need a different layout — they're not read from .env.


# -----------------------------------------------------------------------------
# HOST PORTS (optional)
# -----------------------------------------------------------------------------
# Only MCP is published on the host by default (port 3001). Change
# MCP_PORT if that port is already in use on your machine.
#
# Backend (5001) and SurrealDB (8000) are INTERNAL by default —
# only reachable from within the compose network via their service
# names (`backend`, `surrealdb`). Uncomment the matching `ports:`
# block in docker-compose.yml if you want host-level access for
# local debugging. Don't publish them on a public VPS unless you
# know what you're doing — neither has built-in auth.

MCP_PORT=3001

# BACKEND_PORT=5001  # host port if you uncomment backend's ports: block
# SURREAL_PORT=8000  # host port if you uncomment surrealdb's ports: block


# -----------------------------------------------------------------------------
# MCP SERVER AUTH (optional)
# -----------------------------------------------------------------------------
# If you expose the MCP server to the internet, set a strong API key
# that clients must send in the Authorization header. Leave empty to
# disable auth (fine for localhost-only deployments).

# MCP_API_KEY=
