# =============================================================================
# DeepMiro — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Every variable here is read by docker-compose.yml at the repo root.
# Defaults are sensible for most deployments — in practice you only
# need to set LLM_API_KEY to get started. Everything else has a
# working default.
#
# Railway users: don't commit this file. Paste each variable into the
# Railway dashboard (Variables tab). Railway does not read .env files
# directly — it injects variables at container start.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER (required)
# -----------------------------------------------------------------------------
# Any OpenAI-compatible API works: OpenAI, Fireworks, Anthropic (via proxy),
# Ollama, vLLM, LM Studio, etc. The engine never assumes a specific vendor.
#
# Recommended providers (by cost / quality trade-off):
#
#   Fireworks   — cheapest, fastest, matches production deployment
#                 LLM_BASE_URL=https://api.fireworks.ai/inference/v1
#                 LLM_MODEL_NAME=accounts/fireworks/models/minimax-m2p5
#
#   OpenAI      — highest quality, most expensive
#                 LLM_BASE_URL=https://api.openai.com/v1
#                 LLM_MODEL_NAME=gpt-4o-mini
#
#   Ollama      — fully local, free, slower
#                 LLM_BASE_URL=http://host.docker.internal:11434/v1
#                 LLM_MODEL_NAME=llama3.1:8b
#                 LLM_API_KEY=ollama  (ollama accepts any non-empty value)

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini


# -----------------------------------------------------------------------------
# BOOST LLM (optional)
# -----------------------------------------------------------------------------
# Used for reasoning-heavy tasks like report outline planning and the
# ReportAgent ReACT loop. A larger model here noticeably improves report
# quality at the cost of generating ~5-10% of total tokens. If unset,
# falls back to the primary LLM above.
#
# Production uses gpt-oss-120b via Fireworks:
#   LLM_BOOST_BASE_URL=https://api.fireworks.ai/inference/v1
#   LLM_BOOST_MODEL_NAME=accounts/fireworks/models/gpt-oss-120b

# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=


# -----------------------------------------------------------------------------
# GRAPH EMBEDDINGS (optional)
# -----------------------------------------------------------------------------
# Used to embed entity nodes and post content for the knowledge graph's
# hybrid HNSW + BM25 search. Must match the dimensions of the model —
# nomic-embed-text-v1.5 is 768.
#
# Defaults to nomic-embed via Fireworks (same API key as LLM_API_KEY by
# default). Override to use a different embedding provider.

# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.fireworks.ai/inference
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIMENSIONS=768


# -----------------------------------------------------------------------------
# SURREALDB (required)
# -----------------------------------------------------------------------------
# Connection to the persistent graph store. SURREAL_PASSWORD has NO
# default — docker-compose will refuse to start if this isn't set.
# That's deliberate: an unset password would start a root-privileged
# DB, and button-deploys shouldn't silently ship that to production.
#
# Generate a strong one once:
#   openssl rand -hex 32
#
# On Railway, set this in the Variables tab (use their "Generate"
# button for automatic random values).

SURREAL_USER=root
SURREAL_PASSWORD=
SURREAL_NAMESPACE=mirofish
SURREAL_DATABASE=production

# SurrealDB is NOT published to the host by default — only the
# backend reaches it, via the internal `surrealdb` service name.
# If you want to connect your own SurrealDB client from the host for
# local debugging, uncomment the `ports:` block on the surrealdb
# service in docker-compose.yml (NOT recommended in production).


# -----------------------------------------------------------------------------
# HOST PORTS (optional)
# -----------------------------------------------------------------------------
# Public-facing ports for the services that ARE exposed on the host.
# Change these if 5001 or 3001 are already in use on your machine.
#
# Note: surrealdb is NOT exposed on the host by default — see the
# SURREALDB section above.

BACKEND_PORT=5001
MCP_PORT=3001


# -----------------------------------------------------------------------------
# MCP SERVER AUTH (optional)
# -----------------------------------------------------------------------------
# If you expose the MCP server to the internet, set a strong API key
# that clients must send in the Authorization header. Leave empty to
# disable auth (fine for localhost-only deployments).

# MCP_API_KEY=
